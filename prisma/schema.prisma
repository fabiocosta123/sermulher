generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(cuid())
  name      String
  brand     String?  // Adicionado para bater com seu formulário
  price     Decimal  // Ou Float
  imageUrl  String?
  category  String
  finish    String?
  hexColor  String?
  skinTone  String?
  active    Boolean  @default(true) // O campo que estava faltando!
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteConfig {
  id               Int      @id @default(1)
  heroTitle        String   @default("Sua beleza em evidência")
  heroSubtitle     String?  @default("Descubra a essência da sua beleza com nossos cosméticos exclusivos.")
  heroImageUrl     String?  
  
  
  featuredTitle    String   @default("Essenciais para sua Rotina")
  featuredSubtitle String?  @default("Uma seleção curada de produtos que combinam alta tecnologia e cuidado artesanal.")
  
  heroVideoUrl     String?  
  activeCampaign   String?  

  footerAddress   String?  @default("Registro, São Paulo")
  footerWhatsapp  String?  @default("5513999999999")
  footerInstagram String?  @default("sermulher_cosmeticos")
  footerEmail     String?  @default("contato@sermulher.com.br")
  
  updatedAt        DateTime @updatedAt
}

model Admin {
  id       String @id @default(cuid())
  username String @unique
  password String 
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
}